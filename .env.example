# Kisan Sarthi Environment Variables
# Copy this file to .env and fill in your values.

# -----------------
# GOOGLE GEMINI API (Primary AI Advisory)
# -----------------
# Google Gemini API key for crop health diagnostics & schemes advice.
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Gemini model to use (default: gemini-3.5-flash)
VITE_GEMINI_MODEL=gemini-3.5-flash

# -----------------
# ANTHROPIC CLAUDE API (Optional Legacy Fallback)
# -----------------
# Legacy keys if using the old Anthropic service calls.
# VITE_ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------
# SYSTEM SETTINGS
# -----------------
# App version number displayed in UI and headers.
VITE_APP_VERSION=2.0.0
